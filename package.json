{
  "name": "my-theme",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
       "dev:css": "npx @tailwindcss/cli -i ./assets/css/app.css -o ./dist/assets/css/app.css --watch",

    "build:css": "npx @tailwindcss/cli -i ./assets/css/app.css -o ./dist/assets/css/app.css --minify",

    "dev:js": "npx esbuild ./assets/js/app.js --bundle --outfile=./dist/assets/js/app.js --watch",

    "build:js": "npx esbuild ./assets/js/app.js --bundle --outfile=./dist/assets/js/app.js --minify",

    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\"",

    "build": "npm run build:css && npm run build:js"
  },
  
